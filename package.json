{
  "name": "mypassword",
  "version": "0.0.1",
  "description": "密码管理工具",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "node build.js --run-app",
    "dev:watch": "concurrently \"node build.js --watch\" \"wait-on dist/main/index.js && node build.js --run-app\"",
    "build": "node build.js --package",
    "build:win": "node build.js --package --win",
    "build:mac": "node build.js --package --mac",
    "build:linux": "node build.js --package --linux",
    "test": "jest"
  },
  "build": {
    "appId": "com.mypassword.app",
    "productName": "MyPassword",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/better-sqlite3/**/*",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "artifactName": "${productName} Setup.${ext}",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    },
    "portable": {
      "artifactName": "${productName}.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "resources/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "keywords": [
    "password",
    "manager"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
